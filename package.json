{
  "name": "bouncer",
  "version": "0.6.0",
  "private": true,
  "description": "My personal all-in-one browser extension that fixes my browsing annoyances.",
  "author": "Takumi",
  "license": "MIT",
  "engines": {
    "node": "26.5.0",
    "npm": "11.17.0"
  },
  "scripts": {
    "check:node": "node scripts/check-node.mjs",
    "icons": "node scripts/make-icons.mjs",
    "prebundle": "node scripts/check-node.mjs",
    "bundle": "node scripts/build.mjs",
    "build:chrome": "web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --filename=bouncer-chrome.zip --overwrite-dest",
    "build:firefox": "web-ext build --source-dir=dist --artifacts-dir=web-ext-artifacts --filename=bouncer-firefox.zip --overwrite-dest",
    "build": "npm run bundle && npm run build:chrome && npm run build:firefox",
    "lint": "npm run bundle && web-ext lint --source-dir=dist",
    "typecheck": "tsc --noEmit",
    "start": "npm run bundle && web-ext run --source-dir=dist",
    "dev": "npm run start"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "web-ext": "^10.5.0"
  }
}
