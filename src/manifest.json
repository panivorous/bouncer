{
  "manifest_version": 3,
  "name": "bouncer",
  "version": "0.6.0",
  "description": "My personal all-in-one browser extension that fixes my browsing annoyances.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "bouncer",
    "default_popup": "popup.html"
  },
  "permissions": ["declarativeNetRequest"],
  "optional_permissions": ["userScripts"],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lang-override.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "filmarks_geniee",
        "enabled": true,
        "path": "rules/filmarks-geniee.json"
      },
      {
        "id": "shutto",
        "enabled": true,
        "path": "rules/shutto.json"
      },
      {
        "id": "wovn",
        "enabled": true,
        "path": "rules/wovn.json"
      }
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bouncer@takumi",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
