{
  "manifest_version": 3,
  "name": "bouncer",
  "version": "0.1.0",
  "description": "My personal all-in-one browser extension that fixes my browsing annoyances.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bouncer@takumi",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
